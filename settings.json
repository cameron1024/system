{
  "ssh_connections": [
    {
      "host": "mini",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/cameron/system"
          ]
        }
      ]
    }
  ],
  "status_bar": {
    "show_active_file": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "inline_code_actions": false,
  "gutter": {
    "min_line_number_digits": 2,
    "folds": false,
    "runnables": false,
    "breakpoints": false
  },
  "outline_panel": {
    "dock": "left"
  },
  "debugger": {
    "dock": "bottom"
  },
  "document_folding_ranges": "on",
  "auto_indent_on_paste": false,
  "git_panel": {
    "dock": "left",
    "tree_view": false
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "enabled": true,
    "background_coloring": "disabled",
    "active_line_width": 2,
    "line_width": 1
  },
  "toolbar": {
    "agent_review": false,
    "selections_menu": false,
    "quick_actions": false,
    "breadcrumbs": false
  },
  "tab_bar": {
    "show": false
  },
  "semantic_tokens": "combined",
  "disable_ai": false,
  "which_key": {
    "enabled": true,
  },
  "git": {
    "enable_diff": true,
    "inline_blame": {
      "enabled": true,
    },
  },
  "sticky_scroll": { "enabled": true },

  // "features": {
  //   "edit_prediction_provider": {
  //     "experimental": "sweep",
  //   }
  // },
  "use_on_type_format": false,
  "remove_trailing_whitespace_on_save": false,
  "languages": {
    "Dart": {
      "indent_guides": {
        "active_line_width": 4,
        "line_width": 4
      }
    },
    "Rust": {
      "use_on_type_format": false,
    },
  },
  "relative_line_numbers": "enabled",
  "icon_theme": {
    "mode": "light",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark"
  },
  "audio": {
    "experimental.auto_microphone_volume": true,
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "tool_permissions": {
      "tools": {
        "open": {
          "default": "allow"
        }
      },
      "default": "allow"
    },
    "show_turn_stats": true,
    "play_sound_when_agent_done": "never",
    "use_modifier_to_send": true,
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-opus-4-6",
    },
    "model_parameters": [],
  },
  "project_panel": {
    "dock": "left",
    "bold_folder_labels": true,
    "indent_guides": {
      "show": "always",
    },
  },
  "rounded_selection": true,
  "use_smartcase_search": true,
  "collaboration_panel": {
    "dock": "right",
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "use_system_prompts": true,
  "active_pane_modifiers": {
    "inactive_opacity": 0.7,
  },
  "hover_popover_enabled": false,
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "lsp_pull_diagnostics": {
      "enabled": true,
      "debounce_ms": 50,
    },
    "inline": {
      "enabled": true,
      "update_debounce_ms": 50,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
  },
  "vim_mode": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
  },
  "use_system_path_prompts": false,

  "format_on_save": "off",

  "window_decorations": "server",

  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        // "checkOnSave": false,
        // "check": {
        //   "overrideCommand": ["cargo", "build", "--message-format=json"]
        // }
      }
    }
  },

  /* ============= */
  /* === THEME === */

  "buffer_font_family": "Fira Code",
  "buffer_font_size": 16,
  "buffer_font_features": {
    "calt": true,
    "clig": true,
  },
  "ui_font_family": "Josefin Sans",
  "ui_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Everforest Dark Hard (regular)",
  },
  "buffer_line_height": {
    "custom": 1.4
  },

  // "theme": {
  //   "mode": "dark",
  //   "light": "One Light",
  //   "dark": "One Dark"
  // },
}
